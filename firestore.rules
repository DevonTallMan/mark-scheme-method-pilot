rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students: own document only
    match /classes/{classCode}/students/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }

    // Assignments: any authenticated user can read
    match /classes/{classCode}/assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.role == 'teacher'
        || request.auth.token.classCode == classCode);
    }

    // Leaderboard: any authenticated user can read (anonymous auth is sufficient)
    match /classes/{classCode}/leaderboard/{entry} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
