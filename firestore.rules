rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Students: own document only ──────────────────────────
    match /classes/{classCode}/students/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ── Assignments: all authenticated users can read ────────
    match /classes/{classCode}/assignments/{assignmentId} {
      allow read: if request.auth != null;
      // Write: teacher role OR matching class code claim
      allow write: if request.auth != null
                   && (request.auth.token.role == 'teacher'
                       || request.auth.token.classCode == classCode);
    }

    // ── Leaderboard: scoped to same class ────────────────────
    match /classes/{classCode}/leaderboard/{entry} {
      allow read: if request.auth != null
                  && (request.auth.token.classCode == classCode
                      || get(/databases/$(database)/documents/classes/$(classCode)/students/$(request.auth.uid)).data.classCode == classCode);
      allow write: if false; // server-side only
    }

    // ── Default deny ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
